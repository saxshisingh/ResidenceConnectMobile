# Resolve react_native_pods.rb with node
require Pod::Executable.execute_command(
  'node',
  [
    '-p',
    'require.resolve(
      "react-native/scripts/react_native_pods.rb",
      {paths: [process.argv[1]]},
    )',
    __dir__
  ]
).strip

platform :ios, '15.1'

# =====================================================
# DISABLE NEW ARCHITECTURE
# =====================================================

ENV['RCT_NEW_ARCH_ENABLED'] = '0'

prepare_react_native_project!

# =====================================================
# STATIC FRAMEWORKS
# =====================================================

use_frameworks! :linkage => :static

target 'MyGate' do

  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],

    # =====================================================
    # REACT NATIVE SETTINGS
    # =====================================================

    :hermes_enabled => true,
    :fabric_enabled => false,

    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # =====================================================
  # POST INSTALL
  # =====================================================

  post_install do |installer|

    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )

    installer.pods_project.targets.each do |target|

      target.build_configurations.each do |config|

        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.1'

        # =====================================================
        # DISABLE POD CODE SIGNING
        # =====================================================

        config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
        config.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
        config.build_settings['CODE_SIGNING_IDENTITY'] = ''
        config.build_settings['EXPANDED_CODE_SIGN_IDENTITY'] = ''

        # =====================================================
        # FIX RESOURCE BUNDLE SIGNING
        # =====================================================

        config.build_settings['DEVELOPMENT_TEAM'] = ''

      end
    end

    # =====================================================
    # DISABLE CODE SIGNING FOR RESOURCE BUNDLES
    # =====================================================

    installer.target_installation_results.pod_target_installation_results
      .each do |_pod_name, target_installation_result|

      target_installation_result.resource_bundle_targets.each do |resource_bundle_target|

        resource_bundle_target.build_configurations.each do |config|

          config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
          config.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
          config.build_settings['CODE_SIGNING_IDENTITY'] = ''
          config.build_settings['DEVELOPMENT_TEAM'] = ''

        end
      end
    end
  end
end